<?xml version="1.0" encoding="UTF-8"?>
<bpel:process xmlns:bpel="http://docs.oasis-open.org/wsbpel/2.0/process/executable"
              xmlns:tns="http://bpel.globalbooks.com/PlaceOrder"
              xmlns:cat="http://catalog.globalbooks.com/"
              name="PlaceOrderProcess"
              targetNamespace="http://bpel.globalbooks.com/PlaceOrder">

    <bpel:import importType="http://schemas.xmlsoap.org/wsdl/"
                 location="PlaceOrderArtifacts.wsdl"
                 namespace="http://bpel.globalbooks.com/PlaceOrder"/>

    <bpel:import importType="http://schemas.xmlsoap.org/wsdl/"
                 location="http://localhost:8080/CatalogService/lookup?wsdl"
                 namespace="http://catalog.globalbooks.com/"/>

    <bpel:partnerLinks>
        <bpel:partnerLink name="client"
                          partnerLinkType="tns:PlaceOrder"
                          myRole="PlaceOrderProvider"/>
        <bpel:partnerLink name="catalogService"
                          partnerLinkType="cat:CatalogServicePLT"
                          partnerRole="CatalogServiceProvider"/>
    </bpel:partnerLinks>

    <bpel:variables>
        <bpel:variable name="input" messageType="tns:PlaceOrderRequestMessage"/>
        <bpel:variable name="output" messageType="tns:PlaceOrderResponseMessage"/>
        <bpel:variable name="catalogReq" messageType="cat:lookupBookInput"/>
        <bpel:variable name="catalogRes" messageType="cat:lookupBookOutput"/>
    </bpel:variables>

    <bpel:sequence>
        <bpel:receive name="ReceiveOrder" partnerLink="client" portType="tns:PlaceOrderPortType" operation="process" variable="input" createInstance="yes"/>
        
        <bpel:assign name="AssignCatalogRequest">
            <bpel:copy>
                <bpel:from variable="input" part="isbn"/>
                <bpel:to variable="catalogReq" part="parameters"/>
            </bpel:copy>
        </bpel:assign>
        
        <bpel:invoke name="LookupPriceAndStock" partnerLink="catalogService" portType="cat:CatalogPortType" operation="lookupBook" inputVariable="catalogReq" outputVariable="catalogRes"/>
        
        <bpel:assign name="AssignOrderResponse">
            <bpel:copy>
                <bpel:from>
                    <bpel:literal>ORDER_CREATED_SUCCESSFULLY</bpel:literal>
                </bpel:from>
                <bpel:to variable="output" part="status"/>
            </bpel:copy>
            <!-- In a real BPEL process we would use XPATH to multiply values and invoke the OrdersService REST API. -->
            <bpel:copy>
                <bpel:from><bpel:literal>ORD-BPEL-1024</bpel:literal></bpel:from>
                <bpel:to variable="output" part="orderId"/>
            </bpel:copy>
            <bpel:copy>
                <bpel:from><bpel:literal>45.00</bpel:literal></bpel:from>
                <bpel:to variable="output" part="totalPrice"/>
            </bpel:copy>
        </bpel:assign>
        
        <bpel:reply name="ReplyClient" partnerLink="client" portType="tns:PlaceOrderPortType" operation="process" variable="output"/>
    </bpel:sequence>
</bpel:process>
